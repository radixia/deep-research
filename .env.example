# ── Manus API ────────────────────────────────────────────
MANUS_API_KEY=your_manus_api_key_here
MANUS_WEBHOOK_SECRET=your_webhook_secret_here

# ── Perplexity Sonar ─────────────────────────────────────
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# ── Tavily ───────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ── Firecrawl ────────────────────────────────────────────
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# ── Brave Search ────────────────────────────────────────
BRAVE_API_KEY=your_brave_api_key_here

# ── Optional: Claude for query decomposition ─────────────
ANTHROPIC_API_KEY=

# ── App ──────────────────────────────────────────────────
PORT=3000
APP_ENV=development
# Public base URL for webhooks (no path). Must match URL registered in Manus exactly.
# e.g. https://YOUR_SUBDOMAIN.ngrok-free.app when using ngrok
WEBHOOK_BASE_URL=http://localhost:3000
# Required in production: API key for x-api-key header (auth)
API_KEY=
