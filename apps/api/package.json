{
  "name": "@deep-research/api",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts src/instrumentation.ts --format esm",
    "dev": "tsx --import ./src/instrumentation.ts --env-file=../../.env --watch src/index.ts",
    "start": "node --import ./dist/instrumentation.js dist/index.js"
  },
  "dependencies": {
    "@deep-research/sdk": "workspace:*",
    "@deep-research/types": "workspace:*",
    "@hono/node-server": "^1.12.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "hono": "^4.12.8",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
