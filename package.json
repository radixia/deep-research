{
  "name": "deep-research",
  "private": true,
  "version": "0.1.0",
  "description": "Deep Research Agent — Manus + Firecrawl + Tavily + Perplexity",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm run build && pnpm --filter @deep-research/api run dev",
    "test": "vitest run",
    "test:e2e": "node test/e2e/research.e2e.mjs",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "workspaces": [
    "packages/*",
    "packages/tools/*",
    "apps/*"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "globals": "^17.4.0",
    "prettier": "^3.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
