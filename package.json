{
  "name": "deep-research",
  "private": true,
  "version": "0.1.0",
  "description": "Deep Research Agent — Manus + Firecrawl + Tavily + Perplexity",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm run build && pnpm --filter @deep-research/api run dev",
    "test": "vitest run",
    "test:e2e": "node test/e2e/research.e2e.mjs",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit"
  },
  "workspaces": [
    "packages/*",
    "packages/tools/*",
    "apps/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64"
  }
}
